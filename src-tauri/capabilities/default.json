{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main",
    "screenshot-overlay-*",
    "health-overlay-*"
  ],
  "permissions": [
    "core:default",
    "core:event:default",
    "dialog:default",
    "updater:default",
    "process:default",
    "notification:default"
  ]
}
